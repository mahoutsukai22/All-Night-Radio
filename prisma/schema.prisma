generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Folder {
  id        String          @id @default(uuid())
  name      String
  userId    String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  stations  FolderStation[]

  @@index([userId])
}

model Station {
  id        String          @id @default(uuid())
  name      String
  streamUrl String
  country   String?
  favicon   String?
  createdAt DateTime        @default(now())
  folders   FolderStation[]

  @@unique([name, streamUrl])
}

model FolderStation {
  id        String   @id @default(uuid())
  folderId  String
  stationId String
  createdAt DateTime @default(now())
  folder    Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  station   Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([folderId, stationId])
  @@index([folderId])
  @@index([stationId])
}

model Favorite {
  id        String @id @default(uuid())
  userId    String
  stationId String

  @@unique([userId, stationId])
}
